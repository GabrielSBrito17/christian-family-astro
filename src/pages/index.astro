	const cultos = [
		  { nome: "Culto de Celebração", dia: "Domingo", horario: "10:00 e 18h00", link: "#" },
				{ nome: "Culto o Altar Responde", dia: "Sexta-feira", horario: "20h00", link: "#" },
					{ nome: "Reunião de Oração", dia: "Terça-feira", horario: "20h00", link: "#" },
						{ nome: "Encontro de Jovens", dia: "Sábado", horario: "19h30", link: "#" },
			];

				const eventos = [
				  {
					    titulo: "Conferência Global 2026",
							    data: "15 a 17 de Outubro",
									    local: "Auditório Principal",
											    imagem: "https://unsplash.com",
													    tag: "Conferência",
															    descricao: "Três dias de imersão, adoração e palavra com convidados especiais. Garanta já a sua agenda."
																	  },
																		  {
																			    titulo: "Retiro de Jovens: Conectados",
																					    data: "20 a 22 de Novembro",
																							    local: "Acampamento Quinta do Sol",
																									    imagem: "https://unsplash.com",
																											    tag: "Retiro",
