																															  }
																																];
																																---

																																<html lang="pt-PT">
																																  <head>
																																	    <meta charset="utf-8" />
																																			    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
																																					    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
																																							    <title>{churchName} | Bem-vindo</title>
																																									  </head>
																																										  <body class="bg-gray-50 text-gray-900 font-sans antialiased">

																																											    <!-- 1. CABEÇALHO / NAVEGAÇÃO -->
																																													    <header class="sticky top-0 z-50 bg-white shadow-sm border-b border-gray-100">
																																															      <div class="max-w-6xl mx-auto px-4 h-16 flex items-center justify-between">
																																																		        <a href="#" class="text-xl font-black tracking-tight text-blue-600">{churchName}</a>
																																																						        <nav class="hidden md:flex space-x-8 text-sm font-medium text-gray-600">
																																																										          <a href="#" class="hover:text-blue-600 transition">Início</a>
																																																															          <a href="#agenda" class="hover:text-blue-600 transition">Cultos</a>
																																																																				          <a href="#eventos" class="hover:text-blue-600 transition">Eventos</a>
																																																																									        </nav>
																																																																													        <a href="#eventos" class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold px-4 py-2 rounded-full transition shadow-sm">
																																																																																	          Inscrições Abertas
																																																																																						        </a>
																																																																																										      </div>
																																																																																													    </header>

																																																																																															    <!-- 2. SECÇÃO HERO (DESTAQUE PRINCIPAL) -->
																																																																																																	    <section class="relative bg-gradient-to-br from-blue-900 via-indigo-900 to-slate-900 text-white py-20 px-4 text-center md:py-32">
																																																																																																			      <div class="max-w-3xl mx-auto">
																																																																																																						        <span class="bg-blue-500/20 text-blue-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-blue-500/30">
																																																																																																										          Lugar de Comunhão
																																																																																																															        </span>
																																																																																																																			        <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight mt-6 leading-tight">
																																																																																																																							          Uma igreja de braços abertos para si
																																																																																																																												        </h1>
																																																																																																																																        <p class="text-lg md:text-xl text-slate-300 mt-6 max-w-xl mx-auto leading-relaxed">
																																																																																																																																				          Acompanhe a nossa agenda de cultos, fique por dentro dos próximos retiros e participe na nossa comunidade.
																																																																																																																																									        </p>
																																																																																																																																													        <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
																																																																																																																																																	          <a href="#agenda" class="bg-white text-slate-900 hover:bg-slate-100 font-medium px-8 py-3 rounded-lg shadow transition text-center">
																																																																																																																																																						            Ver Horários de Culto
																																																																																																																																																												          </a>
																																																																																																																																																																	          <a href="#eventos" class="bg-blue-600 hover:bg-blue-500 font-medium px-8 py-3 rounded-lg shadow transition text-center">
																																																																																																																																																																						            Próximos Eventos
																																																																																																																																																																												          </a>
																																																																																																																																																																																	        </div>
																																																																																																																																																																																					      </div>
