																																																																																																																																																																																																																																																																						              </div>
																																																																																																																																																																																																																																																																													              <h3 class="text-xl font-bold text-gray-900 mt-4">{culto.nome}</h3>
																																																																																																																																																																																																																																																																																				            </div>
																																																																																																																																																																																																																																																																																										            <a href={culto.link} class="mt-6 inline-flex items-center text-sm font-semibold text-blue-600 hover:text-blue-700 group">
																																																																																																																																																																																																																																																																																																              Como chegar ou assistir
																																																																																																																																																																																																																																																																																																							              <span class="transform translate-x-0 group-hover:translate-x-1 transition-transform ml-1">→</span>
																																																																																																																																																																																																																																																																																																														            </a>
																																																																																																																																																																																																																																																																																																																				          </div>
																																																																																																																																																																																																																																																																																																																									        ))}
