																																																																																																																																																																																																																																																																																																																																																																																																																																																																					                    <span class="text-gray-500">📍 {evento.local}</span>
																																																																																																																																																																																																																																																																																																																																																																																																																																																																															                  </div>
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																								                  <h3 class="text-2xl font-bold text-gray-900 mt-3 tracking-tight">{evento.titulo}</h3>
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																	                  <p class="text-gray-600 mt-2 text-sm leading-relaxed">{evento.descricao}</p>
																																																																																																																																																																																																																																																																																																																																																																																																																																																																																																										                </div>
